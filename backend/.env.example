# 应用名(FastAPI 标题)
APP_NAME=SYManage
SECRET_KEY=change-me-to-a-long-random-secret
ALGORITHM=HS256

# access token 有效期(分钟)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# PostgreSQL 连接串(psycopg 驱动)
# 格式:postgresql+psycopg://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/symanage

# 启动时自动创建的超级管理员账号
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=change-me

# 以下两项有默认值,可不填(默认都是 "superadmin")
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_WECHAT_ACCOUNT=superadmin
